GITHUB_TOKEN=your_token_here
GITHUB_REPO=owner/repo
CLAUDE_BIN=/usr/local/bin/claude    # path to claude CLI binary

# Scheduler
RALPH_SLEEP_SECONDS=30              # sleep between runs (default 30)
RALPH_QUIET_START=00:00             # quiet hours start — 00:00 = disabled
RALPH_QUIET_END=00:00               # quiet hours end   — 00:00 = disabled

# Resource check
RALPH_RESOURCE_CHECK=true           # set false to disable on non-shared machines
RALPH_MIN_FREE_MEM_MB=256           # skip run if free memory below this
RALPH_MAX_LOAD_PER_CORE=0.8         # skip run if 1-min load avg / num cores exceeds this
